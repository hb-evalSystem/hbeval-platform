# HB-Eval OS Platform — Environment Variables
# =============================================
# Copy to .env.local for local dev; in Vercel add under
# Project Settings → Environment Variables.
# NEVER commit .env.local. NEVER prefix a secret with NEXT_PUBLIC_.

# ── Supabase (public — safe for the browser) ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── Supabase service_role (SECRET — server only, bypasses RLS) ───────────────
# Supabase Dashboard → Project Settings → API → service_role key.
# Used only by /api/agents/provision to write encrypted agent secrets.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── HB-Eval master AES key (SECRET — server only) ────────────────────────────
# MUST be byte-for-byte identical to the AES_KEY set in Railway (the Gateway)
# and to the master key used by the provisioning script. If these differ, the
# Gateway cannot decrypt secrets created by the website.
# Generate once: py -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
HBEVAL_MASTER_AES_KEY=your_master_aes_key_base64_here

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://hbeval.com
